# pyenv
#   For a library or binary, you shouldn't ignore this file.
#   For a specific project or experiment, you might.
# .python-version

# pipenv
#   According to pypa/pipenv#1173, pipenv managed virtualenvs are usually
#   located under ~/.local/share/virtualenvs/.
#   Users may also control this location with PIPENV_VENV_IN_PROJECT=1
#   If you chose to create your virtualenv inside the project, uncomment the following line:
# .venv/

# poetry
#   Similar to pipenv, poetry managed virtualenvs are usually located outside the project.
#   In case you chose to create your virtualenv inside the project, uncomment the following line:
# .venv/

# pdm
#   Similar to pipenv, pdm managed virtualenvs are usually located outside the project.
#   In case you chose to create your virtualenv inside the project, uncomment the following line:
# .venv/

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

